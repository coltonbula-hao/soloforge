# ========================================
# SoloForge 环境变量模板
# ========================================

# ----------------------------------------
# 数据库 (PostgreSQL + PGVector)
# ----------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=soloforge
POSTGRES_PASSWORD=soloforge_secret
POSTGRES_DB=soloforge
DATABASE_URL=postgresql+asyncpg://soloforge:soloforge_secret@postgres:5432/soloforge

# ----------------------------------------
# 缓存与队列 (Redis)
# ----------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----------------------------------------
# AI 层
# ----------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxx
DEEPSEEK_API_KEY=sk-ds-xxxxx
DEFAULT_LLM_PROVIDER=claude

# ----------------------------------------
# 对象存储 (腾讯云 COS / 阿里云 OSS)
# ----------------------------------------
# 腾讯云 COS
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_REGION=ap-guangzhou
COS_BUCKET=soloforge-bucket

# 阿里云 OSS
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=soloforge-bucket

# ----------------------------------------
# API 安全与限流
# ----------------------------------------
API_SECRET_KEY=super-secret-key-change-in-production
API_RATE_LIMIT=100/minute
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3004

# ----------------------------------------
# 日志
# ----------------------------------------
LOG_LEVEL=INFO
